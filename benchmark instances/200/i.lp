agent(1..200).
prefer2(X,Y,X) :- prefer2(X,Y,_), X!=Y.
prefer2(X,Y,X) :- prefer2(X,_,Y), X!=Y.
prefer(X,Y,Z) :- prefer2(X,Y,Z).
prefer(X,Y,Z) :- prefer2(X,Y,Y1), prefer(X,Y1,Z), Y!=Y1, Y!=Z.
